# Copia este archivo a .env.local y llena con los datos de tu proyecto Supabase
# Supabase Dashboard -> Project Settings -> API
NEXT_PUBLIC_SUPABASE_URL=https://TU-PROYECTO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=tu-anon-key

# Portal del empleado (app/portal): el servidor consulta con la service role key
# filtrando por el correo del empleado. NUNCA lleva prefijo NEXT_PUBLIC_ (solo servidor).
# Supabase Dashboard -> Project Settings -> API -> service_role
SUPABASE_SERVICE_ROLE_KEY=tu-service-role-key
